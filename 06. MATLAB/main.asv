%%
clc
clear all
close all
%

%%
clc
close all
clear all

motor = readtable("motor.csv");

t = motor.time;

M1 = motor.M1;
M1_second = M1;
omega = M1;

input_M1 = zeros(length(M1), 1);
input_M1(201:300) = 12 * 0.2;
input_M1(301:400) = 12 * 0.4;
input_M1(401:500) = 12 * 0.6;
input_M1(501:600) = 12 * 0.8;
input_M1(601:700) = 12;
input_M1(1401:1500) = 12 * 0.2;
input_M1(1501:1600) = 12 * 0.4;
input_M1(1601:1700) = 12 * 0.6;
input_M1(1701:1800) = 12 * 0.8;
input_M1(1801:1900) = 12;
input_M1(2001:2100) = 12 * 0.4;
input_M1(2101:2200) = 12 * 0.8;
input_M1(2401:2500) = 12 * 0.4;
input_M1(2501:2600) = 12 * 0.8;
input_M1(2601:2700) = 12 * 0.4;
input_M1(2701:2800) = 12 * 0.8;

for i = 1:1:length(M1)-1
    if M1(i) > 12
        M1(i) = M1(i+1);
    end
end

for i = 10:10:length(M1_second)
    if i <= 10
        M1_second(1 : 10) = mean(M1(1 : 10));
        i = i + 1;
    else
        if input_M1(i - 10 + 1 : i - 1) == 0
            M1_second(i - 10 : i) = 0;
        elseif mean(M1(i - 10 : i)) > 30
            M1_second(i - 10 : i) = 0;
        else
            M1_second(i - 10 : i) = mean(M1(i - 10 : i));
        end
    end
end

for i = 10:10:length(omega)
    if i <= 10
        omega(1 : 10) = sum(M1(1 : 10)) / 4;
        i = i + 1;
    else
        if input_M1(i - 10 + 1 : i - 1) == 0
            omega(i - 10 : i) = 0;
        elseif mean(M1(i - 10 : i)) > 30
            omega(i - 10 : i) = 0;
        else
            omega(i - 10 : i) = sum(M1(i - 10 : i)) / 4;
        end
    end
end

subplot(221), hold on
stairs(t, M1)
plot(t, [M1_second omega input_M1]), ylim([0 35]), xlim([0 3100])
title("Motor 1"), legend(["Pulses [100 ms]", "Mean pulses [1s]", "rad/sec", "Duty cycle"])

