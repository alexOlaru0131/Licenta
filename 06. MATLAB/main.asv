%% Regulator
clc

u0 = 0;
ust = 1;

y0 = 0;
yst = 42.69;

Kp = (yst - y0)/(ust - u0);

y63 = y0 + 0.63*(yst - y0);

Tp = 0.18;
Hp= tf(Kp, [Tp 1]);
Hpd = c2d(Hp, Tp, "zoh");

Ho = tf(1, [Tp 1]);
Hod = c2d(Ho, Tp, "zoh");

Hrd = minreal(Hod / Hpd / (1 - Hod))

%